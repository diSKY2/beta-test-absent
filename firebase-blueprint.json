    "LeaveRequest": {
      "title": "Leave Request",
      "description": "Employee leave or sick requests requiring approval.",
      "type": "object",
      "properties": {
        "employeeId": {
          "type": "string"
        },
        "date": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "photoUrl": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "createdAt": {
          "type": "integer"
        },
        "updatedAt": {
          "type": "integer"
        }
      },
      "required": ["employeeId", "date", "type", "reason", "status", "createdAt", "updatedAt"]
    },
    "OvertimeRequest": {
      "title": "Overtime Request",
      "description": "Employee overtime requests requiring approval.",
      "type": "object",
      "properties": {
        "employeeId": {
          "type": "string"
        },
        "date": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "hours": {
          "type": "number"
        },
        "status": {
          "type": "string"
        },
        "createdAt": {
          "type": "integer"
        },
        "updatedAt": {
          "type": "integer"
        }
      },
      "required": ["employeeId", "date", "reason", "hours", "status", "createdAt", "updatedAt"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "Public company news and announcements.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "createdAt": {
          "type": "integer"
        },
        "updatedAt": {
          "type": "integer"
        }
      },
      "required": ["title", "content", "type", "createdAt", "updatedAt"]
    },
    "CompanyInfo": {
      "title": "Company Info",
      "description": "Company profile details.",
      "type": "object",
      "properties": {
        "key": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "updatedAt": {
          "type": "integer"
        }
      },
      "required": ["key", "content", "updatedAt"]
    },
    "WorkReport": {
      "title": "Work Report",
      "description": "Work reports submitted by employees.",
      "type": "object",
      "properties": {
        "employeeId": {
          "type": "string"
        },
        "date": {
          "type": "string"
        },
        "description": {
          "type": "string"
