    "company_info/{infoId}": {
      "schema": {
        "$ref": "#/entities/CompanyInfo"
      },
      "description": "Public company profile."
    },
    "work_reports/{reportId}": {
      "schema": {
        "$ref": "#/entities/WorkReport"
      },
      "description": "Work reports submitted by employees."
    },
    "galleries/{galleryId}": {
      "schema": {
        "$ref": "#/entities/Gallery"
      },
      "description": "Corporate gallery and media files."
    },
    "agendas/{agendaId}": {
      "schema": {
        "$ref": "#/entities/Agenda"
      },
      "description": "Corporate agendas and event calendar."
    },
    "shift_types/{shiftTypeId}": {
      "schema": {
        "$ref": "#/entities/ShiftType"
      },
      "description": "Shift type configurations."
    },
    "shift_patterns/{patternId}": {
      "schema": {
        "$ref": "#/entities/ShiftPattern"
      },
      "description": "Weekly / monthly roster pattern rotation."
    },
    "subdept_schedule_overrides/{overrideId}": {
      "schema": {
        "$ref": "#/entities/SubdeptScheduleOverride"
      },
      "description": "Overrides to regular roster patterns."
    }
  }
}
