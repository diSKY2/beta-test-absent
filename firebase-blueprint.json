          "type": "integer"
        },
        "updatedAt": {
          "type": "integer"
        }
      },
      "required": ["subDepartmentId", "date", "shift", "createdAt", "updatedAt"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Daily employee attendance record.",
      "type": "object",
      "properties": {
        "employeeId": {
          "type": "string"
        },
        "date": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "timeIn": {
          "type": "string"
        },
        "timeOut": {
          "type": "string"
        },
        "isLate": {
          "type": "boolean"
        },
        "createdAt": {
          "type": "integer"
        },
        "updatedAt": {
          "type": "integer"
        }
      },
      "required": ["employeeId", "date", "status", "createdAt", "updatedAt"]
