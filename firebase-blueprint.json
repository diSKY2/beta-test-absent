        "photoUrl": {
          "type": "string"
        },
        "createdAt": {
          "type": "string"
        }
      },
      "required": ["employeeId", "date", "description"]
    },
    "Gallery": {
      "title": "Gallery",
      "description": "Corporate gallery and media files.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "mediaUrl": {
          "type": "string"
        },
        "createdAt": {
          "type": "string"
        }
      },
      "required": ["mediaUrl", "createdAt"]
    },
    "Agenda": {
      "title": "Agenda",
      "description": "Corporate agendas and event calendar.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "date": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "createdAt": {
          "type": "string"
        }
      },
      "required": ["title", "date", "type", "createdAt"]
    },
    "ShiftType": {
      "title": "Shift Type",
      "description": "Shift type configurations.",
      "type": "object",
      "properties": {
        "subDepartmentId": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "startTime": {
          "type": "string"
        },
        "endTime": {
          "type": "string"
        },
        "isCrossDay": {
          "type": "boolean"
        },
        "isOffDay": {
          "type": "boolean"
        },
        "color": {
          "type": "string"
        },
        "createdAt": {
          "type": "string"
        }
      },
      "required": ["subDepartmentId", "name", "startTime", "endTime"]
