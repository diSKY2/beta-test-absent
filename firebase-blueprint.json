    "ShiftPattern": {
      "title": "Shift Pattern",
      "description": "Weekly / monthly roster pattern rotation.",
      "type": "object",
      "properties": {
        "subDepartmentId": {
          "type": "string"
        },
        "startDate": {
          "type": "string"
        },
        "sequence": {
          "type": "array"
        },
        "updatedAt": {
          "type": "string"
        }
      },
      "required": ["subDepartmentId", "startDate", "sequence"]
    },
    "SubdeptScheduleOverride": {
      "title": "Subdept Schedule Override",
      "description": "Overrides to regular roster patterns.",
      "type": "object",
      "properties": {
        "subDepartmentId": {
          "type": "string"
        },
        "overrideDate": {
          "type": "string"
        },
        "shiftTypeId": {
          "type": "string"
        },
        "updatedAt": {
          "type": "string"
        }
      },
      "required": ["subDepartmentId", "overrideDate"]
    }
