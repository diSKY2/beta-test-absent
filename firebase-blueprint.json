      },
      "description": "Company geofenced locations."
    },
    "departments/{departmentId}": {
      "schema": {
        "$ref": "#/entities/Department"
      },
      "description": "Departments structure."
    },
    "sub_departments/{subDepartmentId}": {
      "schema": {
        "$ref": "#/entities/SubDepartment"
      },
      "description": "Sub-departments structure."
    },
    "employees/{employeeId}": {
      "schema": {
        "$ref": "#/entities/Employee"
      },
      "description": "Employee records."
    },
    "schedules/{scheduleId}": {
      "schema": {
        "$ref": "#/entities/Schedule"
      },
      "description": "Rostering schedules."
    },
    "attendances/{attendanceId}": {
      "schema": {
        "$ref": "#/entities/Attendance"
      },
