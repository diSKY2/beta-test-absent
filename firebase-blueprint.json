    "leave_requests/{requestId}": {
      "schema": {
        "$ref": "#/entities/LeaveRequest"
      },
      "description": "Leave requests for approval."
    },
    "overtime_requests/{requestId}": {
      "schema": {
        "$ref": "#/entities/OvertimeRequest"
      },
      "description": "Overtime requests for approval."
    },
    "announcements/{announcementId}": {
      "schema": {
        "$ref": "#/entities/Announcement"
      },
      "description": "Public company news."
