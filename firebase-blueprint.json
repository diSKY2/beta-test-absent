{
  "entities": {
    "Admin": {
      "title": "Admin",
      "description": "Administrator of the system.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string"
        },
        "createdAt": {
          "type": "integer"
        }
      },
      "required": ["email", "createdAt"]
    },
    "Location": {
      "title": "Location",
      "description": "Company locations and geofencing configurations.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "latitude": {
          "type": "number"
        },
        "longitude": {
          "type": "number"
        },
        "radius": {
          "type": "number"
        },
        "createdAt": {
          "type": "integer"
        },
        "updatedAt": {
          "type": "integer"
        }
      },
      "required": ["name", "latitude", "longitude", "radius", "createdAt", "updatedAt"]
    },
    "Department": {
      "title": "Department",
      "description": "Departments under a location.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "locationId": {
          "type": "string"
        },
        "createdAt": {
          "type": "integer"
        },
        "updatedAt": {
          "type": "integer"
        }
      },
      "required": ["name", "locationId", "createdAt", "updatedAt"]
    },
    "SubDepartment": {
      "title": "Sub Department",
      "description": "Sub-departments or Regu under a department.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "departmentId": {
          "type": "string"
        },
        "createdAt": {
          "type": "integer"
        },
        "updatedAt": {
          "type": "integer"
        }
      },
      "required": ["name", "departmentId", "createdAt", "updatedAt"]
    },
    "Employee": {
      "title": "Employee",
      "description": "Employee profiles.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "locationId": {
          "type": "string"
        },
        "departmentId": {
          "type": "string"
        },
        "subDepartmentId": {
          "type": "string"
        },
        "baseSalary": {
          "type": "number"
        },
        "role": {
          "type": "string"
