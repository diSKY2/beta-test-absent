    "Schedule": {
      "title": "Schedule",
      "description": "Monthly rostering per sub-department per day.",
      "type": "object",
      "properties": {
        "subDepartmentId": {
          "type": "string"
        },
        "date": {
          "type": "string"
        },
        "shift": {
          "type": "string"
